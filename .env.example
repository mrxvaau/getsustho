NODE_ENV=development
PORT=4000
APP_URL=http://127.0.0.1:4000
SESSION_SECRET=change-this-long-random-secret

SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_ANON_KEY=sb_publishable_or_anon_key
SUPABASE_SERVICE_ROLE_KEY=service_role_key_only_for_server

# Configure these inside Supabase Dashboard > Authentication > Providers.
# App callback URL:
# http://127.0.0.1:4000/auth/callback
GOOGLE_ENABLED=true
FACEBOOK_ENABLED=true
