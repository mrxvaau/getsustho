<section class="section">
  <p class="eyebrow">Blog</p>
  <h1>Healthcare updates</h1>
  <div class="grid">
    <% posts.forEach((post) => { %>
      <article class="card">
        <h2><%= post.title %></h2>
        <p><%= post.content.slice(0, 180) %>...</p>
        <a href="/blog/<%= post.slug %>">Read more</a>
      </article>
    <% }) %>
    <% if (!posts.length) { %><p class="empty">No posts published yet.</p><% } %>
  </div>
</section>
